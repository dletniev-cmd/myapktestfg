<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ системный splash screen: по умолчанию ОС автоматически
    рисует launcher-иконку поверх windowBackground (большая иконка по
    центру экрана сразу после нажатия на иконку приложения). Здесь мы
    переопределяем эту иконку на полностью прозрачный drawable, а
    background — на цвет темы устройства, чтобы первый кадр был просто
    однотонным фоном без логотипа. После этого Flutter-движок плавно
    подменяет картинку на UI приложения.
-->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:windowSplashScreenBackground">?android:colorBackground</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
